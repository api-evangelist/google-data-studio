      "item": [
        {
          "id": "4d839992-5d53-4658-bf73-21732c00ca13",
          "name": "Google Data Studio Create a pre-configured embedded Looker Studio report",
          "request": {
            "name": "Google Data Studio Create a pre-configured embedded Looker Studio report",
            "description": {
              "content": "Forwards the user to a pre-configured embedded Looker Studio report using URL parameters. This endpoint provides the same functionality as the standard report creation endpoint but optimized for embedding in iframes. Accepts the same parameters as the /reporting/create endpoint.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "embed",
                "reporting",
                "create"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "c.reportId",
                  "value": "<string>",
                  "description": "The template report ID. If omitted, a blank report is created."
                },
                {
                  "disabled": false,
                  "key": "c.pageId",
                  "value": "<string>",
                  "description": "Specifies the initial page to load in the report."
                },
                {
                  "disabled": false,
                  "key": "c.mode",
                  "value": "<string>",
                  "description": "Sets the initial mode of the report on load. Accepts \"view\" or \"edit\"."
                },
                {
                  "disabled": false,
                  "key": "c.explain",
                  "value": "<boolean>",
                  "description": "Enables the debug/info dialog for troubleshooting."
                },
                {
                  "disabled": false,
                  "key": "r.reportName",
                  "value": "<string>",
                  "description": "Overrides the template report name."
                },
                {
                  "disabled": false,
                  "key": "ds.ds0.connector",
                  "value": "<string>",
                  "description": "Specifies the connector type for the data source configuration. When set, the data source is completely replaced. When omitted, only specified parameters are updated."
                },
                {
                  "disabled": false,
                  "key": "ds.ds0.datasourceName",
                  "value": "<string>",
                  "description": "Sets the display name of the data source."
                },
                {
                  "disabled": false,
                  "key": "ds.ds0.refreshFields",
                  "value": "<boolean>",
                  "description": "Controls whether fields are refreshed on configuration change."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
